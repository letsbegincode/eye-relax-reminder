{
  "name": "eye-relax-reminder",
  "version": "2.0.0",
  "description": "A cute, cross-platform desktop app that reminds you to rest your eyes with an animated cat or custom transparent video overlay.",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "clean": "npx rimraf dist",
    "clean:win": "npx rimraf dist && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "clean:mac": "npx rimraf dist && electron-builder --mac",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux",
    "test:win": "npx rimraf dist && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir && \"dist/win-unpacked/Eye Relax Reminder.exe\"",
    "test:mac": "npx rimraf dist && electron-builder --mac --dir && open \"dist/mac/Eye Relax Reminder.app\"",
    "compress-videos": "node scripts/compress-videos.js"
  },
  "keywords": [
    "eye-care",
    "eye-strain",
    "20-20-20-rule",
    "reminder",
    "health",
    "break-timer",
    "electron",
    "desktop-app",
    "cat",
    "transparent-overlay"
  ],
  "author": "Abhinav (https://github.com/letsbegincode)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/letsbegincode/eye-relax-reminder.git"
  },
  "homepage": "https://github.com/letsbegincode/eye-relax-reminder#readme",
  "bugs": {
    "url": "https://github.com/letsbegincode/eye-relax-reminder/issues"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "cross-env": "^10.1.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.letsbegincode.eye-relax-reminder",
    "productName": "Eye Relax Reminder",
    "asar": true,
    "asarUnpack": [],
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "index.js",
      "preload.js",
      "package.json",
      "settings.default.json",
      "public/**/*",
      "!videos/**",
      "!node_modules/**",
      "!dist/**",
      "!release-build/**",
      "!scripts/**",
      "!*.md",
      "!*.txt",
      "!.git/**",
      "!.editorconfig",
      "!.gitignore"
    ],
    "extraResources": [
      {
        "from": "videos",
        "to": "videos",
        "filter": [
          "*.webm",
          "*.mp4"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.healthcare-fitness",
      "darkModeSupport": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "compression": "maximum"
  }
}
